---
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body class="bg-[#FBFBFB] text-[#0A0A0A] font-sans antialiased tracking-wide">
		<slot />
	</body>
</html>
<style is:global>
	html { scroll-behavior: smooth; }
	::selection { background-color: #0A0A0A; color: #FFFFFF; }
</style>
